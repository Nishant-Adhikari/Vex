{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals"],
    "jsx": "react-jsx",
    "outDir": "./dist/renderer",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"],
      "@vex-lib/*": ["../src/lib/*"]
    }
  },
  "include": ["src/renderer", "src/shared", "../src/lib"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
