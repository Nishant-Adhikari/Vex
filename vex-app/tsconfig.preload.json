{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2024", "DOM"],
    "types": ["node"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "verbatimModuleSyntax": false,
    "outDir": "./dist/preload",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@vex-lib/*": ["../src/lib/*"]
    }
  },
  "include": ["src/preload", "src/shared", "../src/lib"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
